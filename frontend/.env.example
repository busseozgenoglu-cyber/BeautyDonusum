# Frontend ortam değişkenleri — kopyalayıp .env olarak kaydedin
# EXPO_PUBLIC_ prefix'i zorunlu — bu değişkenler istemci tarafında erişilebilir

# Production backend URL'inizi buraya yazın (Railway/Render/Fly.io'dan alacaksınız)
# Örnek: https://beautydonusum-api.up.railway.app
EXPO_PUBLIC_BACKEND_URL=https://BACKEND_URL_BURAYA
