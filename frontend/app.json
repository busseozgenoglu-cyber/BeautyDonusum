{
  "expo": {
    "name": "Ayna Atlas",
    "slug": "ayna-atlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aynaatlas",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.beautydonusum.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Yüz analiziniz için fotoğraf çekiyoruz.",
        "NSPhotoLibraryUsageDescription": "Galerinizdeki fotoğrafı analiz için seçiyoruz.",
        "NSPhotoLibraryAddUsageDescription": "Analiz sonuçlarını galerinize kaydediyoruz.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPrivacyAccessedAPITypes": []
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.beautydonusum.app",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Galerinizdeki fotoğrafı analiz için kullanmak istiyoruz.",
          "cameraPermission": "Yüz analiziniz için kamera kullanmak istiyoruz."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "26c73bc1-b771-468a-9611-e46edf4459d0"
      }
    },
    "owner": "buseozgenoglu"
  }
}
