{
  "expo": {
    "name": "VISAGE Clinic Anteprima",
    "slug": "visage-clinic-anteprima",
    "version": "2.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "visageclinicanteprima",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F6F8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.visageclinic.anteprima",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Klinik öncesi yüz analizi için fotoğraf çekiyoruz.",
        "NSPhotoLibraryUsageDescription": "Galerinizden analiz için bir portre seçmenize izin veriyoruz.",
        "NSPhotoLibraryAddUsageDescription": "İsteğe bağlı olarak rapor ve görselleri kaydetmeniz için kullanılır.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPrivacyAccessedAPITypes": []
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F4F6F8"
      },
      "package": "com.visageclinic.anteprima",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Galerinizdeki fotoğrafı analiz için kullanmak istiyoruz.",
          "cameraPermission": "Yüz analizi için kamera kullanmak istiyoruz."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "26c73bc1-b771-468a-9611-e46edf4459d0"
      }
    },
    "owner": "buseozgenoglu"
  }
}
