# Backend environment variables template
# Copy to .env and fill in values

# MongoDB connection string (required)
MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# Database name (optional, default: test_database)
DB_NAME=beautydonusum

# JWT secret key – use a long random string (required)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin credentials seeded at startup (required)
ADMIN_EMAIL=admin@beautydonusum.com
ADMIN_PASSWORD=change-me-secure-password

# Emergent LLM API key (optional)
EMERGENT_LLM_KEY=your-emergent-llm-api-key

# Allowed CORS origins, comma-separated (optional, default: *)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Server settings (optional)
HOST=0.0.0.0
PORT=8000
WORKERS=1
